# ─── Front-end Vite (exposé au navigateur) ──────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ─── Secrets des Supabase Edge Functions ────────────────────────────────
# À configurer dans Supabase (Edge Functions > Secrets) ou via la CLI :
#   supabase secrets set ANTHROPIC_API_KEY=... SCREENSHOTONE_API_KEY=... KAIROS_PASSWORD=...
#
#   ANTHROPIC_API_KEY      Clé API Anthropic Claude
#   ANTHROPIC_MODEL        (optionnel) modèle, défaut claude-opus-4-8
#   SCREENSHOTONE_API_KEY  Clé d'accès Screenshotone
#   KAIROS_PASSWORD        Mot de passe maître de la page de login
#
# SUPABASE_URL et SUPABASE_SERVICE_ROLE_KEY sont injectés automatiquement
# par Supabase dans les Edge Functions.

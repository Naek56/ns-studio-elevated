# ─── Kairos — variables d'environnement ───────────────────────────────
# Copier ce fichier en `.env.local` (dev) ou configurer sur Vercel (prod).

# Clé API Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Modèle Claude utilisé (optionnel — défaut: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8

# Supabase — projet (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Screenshotone (https://screenshotone.com) — clé d'accès
SCREENSHOTONE_API_KEY=

# Mot de passe maître pour accéder à Kairos (page de login)
KAIROS_PASSWORD=
